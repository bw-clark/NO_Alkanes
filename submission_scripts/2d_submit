#!/bin/bash

for dir in perp/*/; do
    echo "Processing $dir"

    for inp in "$dir"/*.inp; do
        [ -f "$inp" ] || continue

        echo "Submitting $inp"

        sbatch <<EOF
        
#!/bin/bash
#SBATCH --job-name=$jobname
#SBATCH --output=${jobname}.out
#SBATCH --error=${jobname}.err
#SBATCH --time=24:00:00
#SBATCH --nodes=1
#SBATCH --ntasks=10
#SBATCH --mem=64G

module load orca
module load openmpi-ib/intel-2024.0/4.1.6

mkdir -p "\$TMPDIR/$jobname"
SCRATCH="\$TMPDIR/$jobname"

cp "$PWD/$f" "\$SCRATCH/"
cd "\$SCRATCH"

echo "PWD=\$(pwd)"
ls -lah

export OMPI_MCA_btl="^openib"

/sciclone/apps/orca/orca_6_1_1_linux_x86-64_shared_openmpi418_nodmrg/orca $f > "$PWD/${jobname}.log"

cp -f *.gbw *.xyz *.hess "$PWD/" 2>/dev/null || true
rm -rf "\$SCRATCH"
EOFx
    done
done
